int main() {
    int i = 0;
    while (i < 5) {
        putchar('0' + i);
        i++;
    }
    for (i = 5; i < 10; ++i) {
        if (i == 7) {
            continue;
        }
        putchar('0' + i);
        if (i == 8) {
            putchar('7');
        }
    }
    putchar('\n');
    return 0;
}
